{
  "name": "scratch-treasury-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "Local-only treasury ops dashboard for $SCRATCH Phase-2 contracts (chain 4663). Never deployed.",
  "scripts": {
    "dev": "node --use-system-ca ./node_modules/next/dist/bin/next dev",
    "build": "node --use-system-ca ./node_modules/next/dist/bin/next build",
    "start": "node --use-system-ca ./node_modules/next/dist/bin/next start",
    "lint": "next lint",
    "test": "tsx --test src/utils/prizeTable.test.ts src/utils/format.test.ts src/utils/symbolConflict.test.ts",
    "copy-abis": "node scripts/copy-abis.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.8",
    "next": "^14.2.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.21.54",
    "wagmi": "^2.14.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
