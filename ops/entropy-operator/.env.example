# SelfEntropy operator watcher — copy to .env and fill.
# Never commit .env.

OPERATOR_PRIVATE_KEY=
RPC_URL=
# Optional WebSocket RPC for low-latency RandomnessRequested (Alchemy wss://…).
# If unset, inferred from Alchemy HTTPS RPC_URL when possible; else HTTP poll.
# WSS_URL=
SELF_ENTROPY_ADDRESS=0xd305290DaF2b14b60FE3aaE7281C4A001B973aB0

# REQUIRED on the live reveal host (Render). Without this, the watcher exits
# immediately so a habitual laptop `npm run watch` cannot double-reveal.
# I_AM_THE_PRODUCTION_HOST=true

# Persistent paths (Render disk: /data/…). Defaults are local cwd files.
# CHAIN_FILE=./entropy-state.json
# LEDGER_FILE=./payout-ledger.csv

# Optional: ScratchGame for ScratchSettled ledger parse (default prod game).
# GAME_ADDRESS=0xBeD604b5AB226134EdF154cc31881d8C93f4C9e6
# Gate v2 batch-native ScratchSettled (cardIndex) parsing — leave unset for v1.
# GAME_V2=1
# Or: GAME_V2_ADDRESS=0x…  (must match GAME_ADDRESS)

# Optional status/ledger HTTP (Web Service). STATUS_PORT unset = no server.
# STATUS_PORT=10000
# STATUS_TOKEN=long-random-secret

# HTTP poll cadence when ws is down (default 2500). Prefer ≤3000 for ~5s settlement.
# POLL_MS=2500
# Independent nextFulfillSeq lag check (default 60000).
# HEAD_CHECK_MS=60000

# Optional manual recovery lookback (block number). Alias: START_BLOCK
# FROM_BLOCK=
