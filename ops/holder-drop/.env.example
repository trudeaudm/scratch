# Holder-drop daily granter — copy to .env and fill.
# Never commit .env.
#
# CREDITER_PRIVATE_KEY is a dedicated bot wallet — NOT the treasury.
# Worst case if leaked: only the on-chain crediter dailyCap of standard tickets
# (suggested 200/day). Cannot raise caps, cannot grant(), cannot move vault funds.

RPC_URL=
CREDITER_PRIVATE_KEY=

# Optional: bot address for dry-run without loading the key
# CREDITER_ADDRESS=0x…

# Production defaults (override if redeployed)
STANDARD_SOURCE=0xC94894Cd3986E2D0f85616a0Dc59914f1057f003
SCRATCH=0xf5E5f4D3C34A14B2fDfD59584Fe555Cd5e21F196

# Min SCRATCH balance (wei). Default = 1_000_000e18
# THRESHOLD=1000000000000000000000000

# Tickets (wei) credited to each recipient. Default = 1e18
# TICKETS_EACH=1000000000000000000

# Comma-separated extra exclusions (protocol addresses are already baked into src/exclusions.js)
# EXCLUDE=

# Blockscout API (token holders pagination)
# BLOCKSCOUT_API=https://robinhoodchain.blockscout.com/api

# Safety: dry-run is the default. Set RUN=true to broadcast credits.
# DRY_RUN=true
# RUN=true
