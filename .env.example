# Phase-2 deploy env for script/Deploy2.s.sol
# Copy to `.env` and fill one column (production OR §9 rehearsal). Never commit secrets.
#
# Usage:
#   set -a && source .env && set +a
#   forge script script/Deploy2.s.sol:Deploy2 --rpc-url $RPC_URL --broadcast --slow
#
# Columns below: PRODUCTION | §9 REHEARSAL (same script / same bytecode — env only)

# =============================================================================
# Wallet / chain
# =============================================================================
# PRIVATE_KEY     hardware-backed deployer EOA | fresh burner EOA (abandon after rehearsal)
# RPC_URL         Robinhood Chain 4663 RPC     | same
PRIVATE_KEY=
RPC_URL=

# =============================================================================
# Core addresses
# =============================================================================
# PRODUCTION                              | §9 REHEARSAL
# SCRATCH         real $SCRATCH CA            | throwaway ERC-20 from burner deploy
# TREASURY        ops multisig                | rehearsal EOA / temp multisig
SCRATCH=
TREASURY=

# =============================================================================
# StakingVault
# =============================================================================
# PRODUCTION                              | §9 REHEARSAL
# EMISSION_RATE   23148148148148148 (~2.31e16 ≈ 2000 tickets/day) | 1000000000000000000 (1e18 — ~1 ticket/sec sole staker)
# MIN_STAKE       1500000000000000000000000 (1500000e18 — live site threshold) | 1000000000000000000 (1e18)
EMISSION_RATE=
MIN_STAKE=

# =============================================================================
# ScratchGame / StandardTicketSource
# =============================================================================
# PRODUCTION                              | §9 REHEARSAL
# RESCUE_DELAY    86400 (24h)                 | 600 (10 min)
# PROMO_DAILY_CAP 1000000000000000000000 (1000e18 ticket-wei grant cap) | 1000000000000000000000 (same) or lower
RESCUE_DELAY=
PROMO_DAILY_CAP=

# =============================================================================
# Randomness provider — pick ONE mode
# =============================================================================
# RANDOMNESS_PROVIDER  chainlink | self
#
# --- Mode: chainlink (ChainlinkVRFAdapter) ---
# VRF_COORDINATOR / VRF_KEYHASH / VRF_SUB_ID required. Coordinator on 4663 is an open gate (GATES.md).
# VRF_NATIVE_PAYMENT  true (ETH gas on 4663)
#
# --- Mode: self (SelfEntropyProvider — interim until oracle on 4663) ---
# OPERATOR            EOA that runs ops/entropy-operator reveals
# ENTROPY_COMMITMENT  tip from `npm run generate` in ops/entropy-operator (bytes32)
#
RANDOMNESS_PROVIDER=self

# chainlink mode:
VRF_COORDINATOR=
VRF_KEYHASH=
VRF_SUB_ID=
VRF_NATIVE_PAYMENT=true

# self mode:
OPERATOR=
ENTROPY_COMMITMENT=

# =============================================================================
# Prize tables (ABI-encoded ScratchGame.PrizeRow[])
# =============================================================================
# Encoding: each table is `abi.encode(PrizeRow[])` where PrizeRow =
#   (address asset, uint96 amountOrBps, bool isBpsOfPool, uint32 cumOdds)
#
# On-chain rules (ScratchGame.setPrizeTable):
#   - cumOdds strictly increasing
#   - last row MUST be no-win: asset = address(0), cumOdds = 1000000 (1e6)
#
# Deploy2 also asserts STANDARD rows are $SCRATCH-only (GATES.md); terminal stays address(0).
# PREMIUM may include USDG / other assets once known (GATES.md).
#
# Encode with cast (Solidity tuple array syntax), then paste the 0x… hex:
#   cast abi-encode "((address,uint96,bool,uint32)[])" \
#     "[(SCRATCH,1000000000000000000,false,100000),(0x0000000000000000000000000000000000000000,0,false,1000000)]"
#
# PRODUCTION: real odds / EV-tuned tables
# REHEARSAL:  simple high-win tables OK (throwaway token as SCRATCH asset)
PREMIUM_PRIZE_TABLE=
STANDARD_PRIZE_TABLE=

# =============================================================================
# Post-deploy (manual — not in script)
# =============================================================================
# 1. TREASURY must acceptOwnership on each (Ownable2Step) — addresses printed at end of
#    Deploy2 console output as a checklist:
#      - ScratchGame
#      - PrizeVault
#      - StandardTicketSource
# 2. Fund PrizeVault with the 20% seed (treasury multisig tx).
# 3. If chainlink: add VRF consumer = ChainlinkVRFAdapter on the subscription.
# 4. If self: run ops/entropy-operator watch with OPERATOR key + ENTROPY state file.

# =============================================================================
# Fork integration suite (test/fork) — optional overrides
# =============================================================================
# Defaults = canonical Robinhood Chain 4663 addresses if unset (see README).
# USDG=
# WETH9=
# UNISWAP_V3_FACTORY=
# NPM=
